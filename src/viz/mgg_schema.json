{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "mark": {
      "type": "string",
      "enum": [
        "bar", "cell", "dot", "link", "point",
        "rect", "rectX", "rectY", "text", "arrow", "axis",
        "axisX", "axisY"
      ]
    }
  },
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "mark": { "const": "bar" },
        "x": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "y": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "width": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "height": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "color": { "oneOf": [{"type": "number"}, {"type": "string"}] }
      },
      "required": ["x", "y", "width", "height"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "cell" },
        "x": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "y": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "size": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "fill": { "oneOf": [{"type": "number"}, {"type": "string"}] }
      },
      "required": ["x", "y", "size"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "dot" },
        "x": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "y": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "size": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "color": { "oneOf": [{"type": "number"}, {"type": "string"}] }
      },
      "required": ["x", "y", "size"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "link" },
        "x1": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "y1": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "x2": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "y2": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "stroke": { "type": "string" }
      },
      "required": ["x1", "y1", "x2", "y2"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "point" },
        "x": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "y": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "radius": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "color": { "type": "string" }
      },
      "required": ["x", "y"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "rect" },
        "x": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "y": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "width": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "height": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "fill": { "oneOf": [{"type": "number"}, {"type": "string"}] }
      },
      "required": ["x", "y", "width", "height"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "rectX" },
        "x": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "width": {"oneOf": [{"type": "number"}, {"type": "string"}] },
        "height": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "stroke": { "type": "string" }
      },
      "required": ["x", "width", "height"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "rectY" },
        "y": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "width": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "height": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "stroke": { "type": "string" }
      },
      "required": ["y", "width", "height"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "text" },
        "x": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "y": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "text": { "oneOf": [{"type": "number"}, {"type": "string"}] }
      },
      "required": ["x", "y", "text"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "arrow" },
        "x1": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "y1": { "oneOf": [{"type": "number"}, {"type": "string"}]},
        "x2": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "y2": { "oneOf": [{"type": "number"}, {"type": "string"}] },
        "stroke": { "type": "string" }
      },
      "required": ["x1", "y1", "x2", "y2"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "axis" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "orientation": { "type": "string", "enum": ["horizontal", "vertical"] },
        "ticks": { "type": "number" }
      },
      "required": ["x", "y", "orientation"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "axisX" },
        "x": { "type": "number" },
        "orientation": { "type": "string", "enum": ["horizontal", "vertical"] },
        "ticks": { "type": "number" }
      },
      "required": ["x", "orientation"]
    },
    {
      "type": "object",
      "properties": {
        "mark": { "const": "axisY" },
        "y": { "type": "number" },
        "orientation": { "type": "string", "enum": ["horizontal", "vertical"] },
        "ticks": { "type": "number" }
      },
      "required": ["y", "orientation"]
    }
  ]
}
